{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "hazakura-note",
  "version": "0.3.0",
  "identifier": "lab.hazakura.note",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hazakura-note",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns"],
    "fileAssociations": [
      {
        "name": "Text files",
        "ext": [
          "md",
          "markdown",
          "mdown",
          "txt",
          "text",
          "log",
          "json",
          "jsonl",
          "yaml",
          "yml",
          "toml",
          "csv",
          "tsv",
          "css",
          "html",
          "xml",
          "ini",
          "conf"
        ],
        "contentTypes": ["public.text", "public.plain-text", "public.json"],
        "role": "Editor",
        "rank": "None"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
