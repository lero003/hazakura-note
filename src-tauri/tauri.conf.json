{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "hazakura-note",
  "version": "0.5.0",
  "identifier": "lab.hazakura.note",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hazakura-note",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.icns"],
    "fileAssociations": [
      {
        "name": "Markdown files",
        "ext": ["md", "markdown", "mdown"],
        "contentTypes": ["public.text"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "Text files",
        "ext": ["txt", "text", "log"],
        "contentTypes": ["public.plain-text"],
        "role": "Editor",
        "rank": "Default"
      },
      {
        "name": "Data files",
        "ext": ["json", "jsonl", "yaml", "yml", "toml", "csv", "tsv"],
        "contentTypes": ["public.text", "public.json"],
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "name": "Code files",
        "ext": ["css", "html", "xml", "ini", "conf"],
        "contentTypes": ["public.text"],
        "role": "Editor",
        "rank": "Alternate"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "signingIdentity": "-"
    }
  }
}
